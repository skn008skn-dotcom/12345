#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
#include <iomanip>
#include <clocale>

struct Room {
    int number;
    std::string type;
    double basePrice;
    bool hasAC;
    bool hasMiniBar;
};

struct Guest {
    int id;
    std::string name;
    std::string contact;
    std::string passport;
};

struct Booking {
    int id;
    int roomNumber;
    int guestId;
    std::string checkIn; 
    std::string checkOut;
    double totalCost;
    bool isPaid;
};

class RoomRepository {
    std::vector<Room> rooms;
public:
    void add(Room r) { rooms.push_back(r); }
    std::vector<Room> getAll() { return rooms; }
    Room* getByNumber(int num) {
        for (auto& r : rooms) if (r.number == num) return &r;
        return nullptr;
    }
};

class GuestRepository {
    std::vector<Guest> guests;
public:
    void add(Guest g) { guests.push_back(g); }
    Guest* getById(int id) {
        for (auto& g : guests) if (g.id == id) return &g;
        return nullptr;
    }
};

class BookingRepository {
    std::vector<Booking> bookings;
public:
    void add(Booking b) { bookings.push_back(b); }
    std::vector<Booking>& getAll() { return bookings; }
    void remove(int id) {
        bookings.erase(std::remove_if(bookings.begin(), bookings.end(),
            [id](const Booking& b) { return b.id == id; }), bookings.end());
    }
};

class BookingService {
    RoomRepository& rooms;
    GuestRepository& guests;
    BookingRepository& bookings;
public:
    BookingService(RoomRepository& r, GuestRepository& g, BookingRepository& b)
        : rooms(r), guests(g), bookings(b) {
    }

    bool createBooking(int bId, int roomNum, int gId, std::string in, std::string out) {
        if (!rooms.getByNumber(roomNum) || !guests.getById(gId)) return false;

        double price = rooms.getByNumber(roomNum)->basePrice;
        bookings.add({ bId, roomNum, gId, in, out, price, false });
        return true;
    }
};

